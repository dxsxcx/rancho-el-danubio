---
// src/components/Ubicacion.astro
const veracruz = ['Jesús Carranza (Acopio Principal)', 'Uxpanapa', 'Hidalgotitlán', 'San Juan Evangelista', 'Catemaco', 'Santiago Tuxtla', 'Las Choapas'];
const oaxaca = ['Juchitán', 'San Juan Guichicovi', 'Matías Romero Avendaño'];
---
<section class="py-28 bg-danubio-chalk border-b border-danubio-copper/30">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="text-xs font-black tracking-[0.25em] text-danubio-saddle uppercase block mb-3">Logística Comercial</span>
      <h2 class="text-3xl md:text-5xl font-black text-danubio-bark tracking-tight uppercase leading-none">Zonas de Cobertura</h2>
      <div class="w-20 h-[3px] bg-danubio-saddle mx-auto mt-5"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch max-w-6xl mx-auto">
      <div class="lg:col-span-1 flex flex-col gap-6 justify-between">
        
        <div class="bg-white border-2 border-danubio-brand/20 p-6 rounded-xl shadow-lg">
          <h3 class="font-black text-danubio-bark text-sm tracking-wider uppercase border-b-2 border-danubio-saddle/30 pb-3 mb-4 flex items-center gap-2">
            <span class="text-lg">📍</span> Operación Veracruz
          </h3>
          <ul class="space-y-3 text-sm text-danubio-bark font-medium tracking-wide">
            {veracruz.map(m => (
              <li class="flex items-start gap-2">
                <span class="text-danubio-saddle font-bold">•</span>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="bg-white border-2 border-danubio-brand/20 p-6 rounded-xl shadow-lg">
          <h3 class="font-black text-danubio-bark text-sm tracking-wider uppercase border-b-2 border-danubio-saddle/30 pb-3 mb-4 flex items-center gap-2">
            <span class="text-lg">📍</span> Operación Oaxaca
          </h3>
          <ul class="space-y-3 text-sm text-danubio-bark font-medium tracking-wide">
            {oaxaca.map(m => (
              <li class="flex items-start gap-2">
                <span class="text-danubio-saddle font-bold">•</span>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="lg:col-span-2 min-h-[400px] bg-white border-2 border-danubio-brand/20 rounded-xl overflow-hidden shadow-2xl relative group">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15212.721495945396!2d-95.03578765487737!3d17.47502758872589!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85c1ca59c0f997cb%3A0xc3fde52b57bfdf8b!2s96950%20Jes%C3%BAs%20Carranza%2C%20Ver.!5e0!3m2!1ses-419!2smx!4v1716500000000!5m2!1ses-419!2smx" 
          class="w-full h-full grayscale contrast-[1.1] group-hover:grayscale-0 transition-all duration-500 ease-in-out" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
    
  </div>
</section>